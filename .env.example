# =============================================================================
# Eat Out Adviser - Variáveis de Ambiente
# =============================================================================
# Copiar para .env e preencher com os valores correctos:
#   cp .env.example .env
# =============================================================================

# --- Base de Dados (PostgreSQL 17 + pgvector) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eat_out_adviser"

# --- Autenticação (Better Auth) ---
BETTER_AUTH_SECRET="gerar-com-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (opcional)
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Passkeys / WebAuthn
PASSKEY_RP_ID="localhost"
PASSKEY_ORIGIN="http://localhost:3000"

# --- IA: Google Gemini ---
GEMINI_API_KEY=""

# --- Embeddings ---
# Provider: "gemini" (API) ou "ollama" (local)
EMBEDDING_PROVIDER="ollama"

# Ollama (apenas se EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text-v2"

# --- Aplicação ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
