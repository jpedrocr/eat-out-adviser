# ==============================================================================
# Eat Out Adviser - Variaveis de Ambiente
# ==============================================================================
# Copiar para .env.local (desenvolvimento) ou .env (producao)
# cp docker/.env.example .env.local
# ==============================================================================

# --- Aplicacao ---
APP_PORT=3000
NODE_ENV=development

# --- Base de Dados (PostgreSQL 17 + pgvector) ---
DB_NAME=eatoutadviser
DB_USER=eatout
DB_PASSWORD=changeme
DB_PORT=5432
DATABASE_URL=postgresql://eatout:changeme@localhost:5432/eatoutadviser

# --- Autenticacao (Better Auth) ---
BETTER_AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (opcional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- IA: Google Gemini ---
GEMINI_API_KEY=

# --- IA: Ollama (embeddings locais) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PORT=11434

# --- Sentry (monitorizacao de erros, opcional) ---
SENTRY_DSN=
