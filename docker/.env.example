# =============================================================================
# Docker Compose - Variaveis de Ambiente
# =============================================================================
# Copiar para docker/.env:
#   cp docker/.env.example docker/.env
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Ollama
OLLAMA_PORT=11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2

# Aplicacao (apenas producao)
APP_PORT=3000
BETTER_AUTH_SECRET=gerar-com-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
GEMINI_API_KEY=
EMBEDDING_PROVIDER=ollama
